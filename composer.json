{
    "name": "albaaguado/ayudawp-events-pro",
    "description": "Plugin WordPress profesional con CI/CD",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "Albaaguado\\AyudawpEventsPro\\": "src/"
        }
    },
    "authors": [
        {
            "name": "albaaguado",
            "email": "alba@doowebs.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "audit": {
            "block-insecure": false
        },
        "platform": {
            "php": "8.0.0"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3"
    }
}
